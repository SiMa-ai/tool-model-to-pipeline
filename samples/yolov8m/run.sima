# build-model.sima
echo "Starting Pipeline building process..."
model 
{
        cd /home/docker/sima-cli/tool-model-to-pipeline \
        && source ~/.bashrc && sima-model-to-pipeline model-to-pipeline --config-yaml tool-model-to-pipeline/samples/yolov8m/yolov8m.yaml    
}
mpk 
{
        cd /home/docker/sima-cli/tool-model-to-pipeline \
        && source ~/.bashrc && sima-model-to-pipeline model-to-pipeline --config-yaml tool-model-to-pipeline/samples/yolov8m/yolov8m.yaml
}

echo "✅ All done!"