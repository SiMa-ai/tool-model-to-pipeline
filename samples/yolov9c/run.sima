# build-model.sima
echo "Starting Pipeline building process..."
model 
{
        cd /home/docker/sima-cli/tool-model-to-pipeline \
        && source ~/.bashrc && sima-model-to-pipeline model-to-pipeline --config-yaml samples/yolov9c/yolov9c.yaml    
}
mpk 
{
        cd /home/docker/sima-cli/tool-model-to-pipeline \
        && source ~/.bashrc && sima-model-to-pipeline model-to-pipeline --config-yaml samples/yolov9c/yolov9c.yaml
}

echo "✅ All done!"